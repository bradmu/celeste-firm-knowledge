{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_disabled_PreToolUse_check_ids": "Celeste prototyping uses ShadCN, not IDS. To re-enable IDS enforcement, restore the Write|Edit matcher block under hooks.PreToolUse pointing at .claude/hooks/check-ids.js.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-prime.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/check-template-update.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/enforce-sandbox.js"
          }
        ]
      }
    ]
  }
}
